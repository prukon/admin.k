# ── ОС и редакторы ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.iml
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Node / фронтенд ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.vite/
public/hot
public/build/
*.map

# ── PHP / Composer / Laravel ───────────────────────────────────
vendor/
composer.phar
.phpunit.result.cache
phpunit.xml.cache

# окружение
.env
.env.*
!.env.example
.env.backup

# storage и логи (runtime-файлы игнорим, но "якорные" .gitignore — отслеживаем)
storage/*.key
storage/debugbar/

# Важно: нельзя игнорировать каталог целиком, иначе нельзя "разигнорить" файл внутри.
storage/framework/*
!storage/framework/cache/
!storage/framework/cache/.gitignore
!storage/framework/cache/data/
!storage/framework/cache/data/.gitignore
!storage/framework/sessions/
!storage/framework/sessions/.gitignore
!storage/framework/views/
!storage/framework/views/.gitignore

storage/logs/*
!storage/logs/.gitignore

# Если хотите оставить только symlink, не файлы:
public/storage

# bootstrap cache (оставляем .gitignore в каталоге)
bootstrap/cache/*
!bootstrap/cache/.gitignore

# Homestead / Valet / прочее локальное
Homestead.yaml
Homestead.json

# Временные/служебные
*.pid
*.seed
*.pid.lock
